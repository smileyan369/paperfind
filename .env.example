# Copy this file to .env, or configure the AI service in the app Settings page.
#
# Values saved from the Settings page are stored in the local SQLite database
# and take precedence over empty environment defaults.

# LLM API (OpenAI-compatible Chat Completions API)
# Examples:
# OpenAI:   LLM_BASE_URL=https://api.openai.com/v1          LLM_MODEL=gpt-4o-mini
# Groq:     LLM_BASE_URL=https://api.groq.com/openai/v1     LLM_MODEL=llama-3.1-8b-instant
# DeepSeek: LLM_BASE_URL=https://api.deepseek.com/v1        LLM_MODEL=deepseek-chat
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Optional proxy, for example: http://127.0.0.1:7890
PROXY_URL=

# SQLite database path
DATABASE_URL=sqlite+aiosqlite:///./data/papers.db

# Daily crawl schedule, 24-hour local time
CRAWL_SCHEDULE_HOUR=8
CRAWL_SCHEDULE_MINUTE=0

# Crawl rate limiting
CRAWL_RATE_LIMIT_RPS=3

# AI summarization
SUMMARY_BATCH_SIZE=5
SUMMARY_MAX_RETRIES=3

# Institutional access cookies, optional
IEEE_INSTITUTION_COOKIE=
ACM_INSTITUTION_COOKIE=

# Logging
LOG_LEVEL=INFO
